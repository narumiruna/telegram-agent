# Telegram Bot API token from @BotFather.
BOT_TOKEN=

# Optional: comma-separated Telegram chat_id or user_id values allowed to use the bot.
# Leave empty to allow everyone.
BOT_WHITELIST=

# Maximum consecutive replies to other bots in bot-to-bot reply chains.
# Use 0 to never reply to other bots.
BOT_MAX_CONSECUTIVE_REPLIES_TO_BOTS=1

# Agent Skills directory and optional comma-separated skill names to load.
# Leave BOT_ENABLED_SKILLS empty to load every skill under BOT_SKILLS_DIR.
BOT_SKILLS_DIR=.agents/skills
BOT_ENABLED_SKILLS=

# Optional: comma-separated Telegram chat_id or user_id values allowed to manage skills.
# Leave empty to reuse BOT_WHITELIST.
BOT_SKILL_ADMINS=

# OpenAI-compatible Chat Completions endpoint.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional Logfire settings. Currently reserved for future instrumentation.
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=dev
